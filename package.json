{
  "name": "xtream-web-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 0.0.0.0 --port 8080",
    "dev:server": "tsx server/index.ts",
    "build": "tsc -b && vite build && esbuild server/index.ts --bundle --platform=node --format=esm --packages=external --outdir=dist-server",
    "build:dev": "vite build --mode development",
    "start": "NODE_ENV=production node dist-server/index.js",
    "preview": "vite preview --host 0.0.0.0 --port 5173",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.13",
    "compression": "^1.8.1",
    "cookie": "^1.0.2",
    "express": "^5.1.0",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.468.0",
    "mpegts.js": "^1.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.9",
    "concurrently": "^10.0.3",
    "esbuild": "^0.28.1",
    "jsdom": "^26.1.0",
    "nock": "^14.0.10",
    "supertest": "^7.1.4",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wait-on": "^8.0.4"
  }
}
